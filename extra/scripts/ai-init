#!/usr/bin/env bash

set -euo pipefail

dotf_root="${DOTF:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)}"
project_root="${1:-$(pwd)}"

mkdir -p "$project_root/.ai"
cp -R "$dotf_root/ai"/. "$project_root/.ai"
cp "$dotf_root/AGENTS.md" "$project_root/AGENTS.md"
cp "$dotf_root/CLAUDE.md" "$project_root/CLAUDE.md"

