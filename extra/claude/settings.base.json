{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(go *)",
      "Bash(rtk *)",
      "Bash(bd *)",
      "Bash(wait)",
      "Skill(beads)",
      "Skill(commit)",
      "WebSearch",
      "Bash(~/.dotfiles/core/ai/skills/commit/scripts/commit-scopes.sh *)"
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "advisorModel": "opus",
  "statusLine": {
    "type": "command",
    "command": "blf claude-statusline"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  }
}
