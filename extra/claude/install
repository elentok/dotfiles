#!/usr/bin/env bash

set -euo pipefail

source "$DOTF/framework.sh"

if dotf-command-missing claude; then
  npm install -g @anthropic-ai/claude-code
  claude migrate-installer
fi

mkdir -p ~/.claude

# Managed, version-controlled config lives in settings.local.json, which has
# higher precedence and which Claude never rewrites at runtime. settings.json is
# left as Claude's runtime scratchpad (model, effort, etc.) and stays untracked.
dotf-symlink "$DOTF/extra/claude/settings.local.json" ~/.claude/settings.local.json
