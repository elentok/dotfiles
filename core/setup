#!/usr/bin/env bash
#
# Supported ENV variables:
#
# - CAN_SUDO (defaults to "yes", set to "no" to skip sudo calls)
# - SETUP_BREW (defaults to "yes", set to "no" to skip homebrew setup)

set -euo pipefail

export CAN_SUDO="${CAN_SUDO:-yes}"
export SETUP_BREW="${SETUP_BREW:-yes}"

function main() {
  dfl mkdir ~/.config

  if [ "$SETUP_BREW" != "no" ]; then
    install-homebrew
    dfl shell "Installing Homebrew bundle" -- brew bundle --file "$DFL_ROOT/Brewfile" install
  fi

  if [ "$CAN_SUDO" != "no" ]; then
    install-apt-pkgs
  fi

  install-personal-cli-tools

  dfl git-clone --update elentok/stuff.nvim ~/dev/nvim/stuff.nvim

  local components=(
    fish
    nvim
    git
    ripgrep
    tig
    bat
    bash
    tmux
    yazi
    nodejs
    python
    ai
    kitty
  )
  dfl install "${components[@]}"

  if dfl os is-mac; then
    dfl symlink ~/Library/Mobile\ Documents/com~apple~CloudDocs ~/iCloud
    dfl install osx-tuning

    if test ! -e ~/.hushlogin; then
      touch ~/.hushlogin
    fi
  fi
}

function install-homebrew() {
  if dfl os is-mac; then
    export PATH="/opt/homebrew/bin:$PATH"
  else
    export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
  fi

  if dfl has-command brew; then
    return
  fi

  if dfl os is-linux; then
    dfl pkg apt install curl
  fi

  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

function install-apt-pkgs() {
  if dfl os is-linux; then
    local packages=(
      build-essential
      cmake
      libreadline-dev
      cifs-utils
      curl
      git
      htop
      ncdu
      plantuml
      unzip
      wget
      qalc
      ffmpeg
      pv
      fish
      xclip
      toilet
    )
    dfl pkg apt install "${packages[@]}"
  fi
}

function install-personal-cli-tools() {
  # Install these personal tools the same way on macOS and Linux instead of
  # relying on Homebrew casks, which are macOS-only.
  local packages=(
    elentok/dff
    elentok/gx
    elentok/colr
    elentok/blf
    elentok/qmkmd
  )
  dfl pkg github install "${packages[@]}"
}

main "$@"
