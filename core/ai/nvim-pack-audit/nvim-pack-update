#!/usr/bin/env bash

set -euo pipefail

script_dir=$(
  cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd
)
repo_root=$(
  git -C "$script_dir" rev-parse --show-toplevel
)

lockfile_rel="core/nvim/nvim-pack-lock.json"
lockfile_path="$repo_root/$lockfile_rel"
schema_path="$script_dir/audit-schema.json"
prompt_path="$script_dir/security-audit-prompt.md"

tmp_root=""
keep_tmp=1

usage() {
  cat <<'EOF'
Usage: core/ai/nvim-pack-audit/nvim-pack-update

Runs a staged vim.pack.update() in a temporary clone, audits changed plugin
revisions with Codex, shows a summary, and optionally promotes the audited
lockfile into the real repo with a commit.
EOF
}

cleanup() {
  if [[ -n "$tmp_root" && -d "$tmp_root" && "$keep_tmp" -eq 0 ]]; then
    rm -rf -- "$tmp_root"
  fi
}
trap cleanup EXIT

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

if [[ $# -gt 0 ]]; then
  case "${1:-}" in
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
fi

for cmd in git jq nvim codex; do
  command -v "$cmd" >/dev/null 2>&1 || die "missing required command: $cmd"
done

[[ -f "$lockfile_path" ]] || die "missing lockfile: $lockfile_path"
[[ -f "$schema_path" ]] || die "missing schema: $schema_path"
[[ -f "$prompt_path" ]] || die "missing prompt: $prompt_path"

if git -C "$repo_root" ls-files -u -- "$lockfile_rel" | grep -q .; then
  printf '%s\n' "lockfile has unmerged changes: $lockfile_rel" >&2
  printf '%s\n' "resolve the conflict before running nvim-pack-update" >&2
  exit 1
fi

if grep -nE '^(<<<<<<<|=======|>>>>>>>)' "$lockfile_path" >/dev/null 2>&1; then
  printf '%s\n' "lockfile appears to contain merge conflict markers: $lockfile_rel" >&2
  printf '%s\n' "resolve the conflict before running nvim-pack-update" >&2
  exit 1
fi

tmp_root=$(mktemp -d "${TMPDIR:-/private/tmp}/nvim-pack-audit-XXXXXX")
staging_repo="$tmp_root/repo"
xdg_root="$tmp_root/xdg"
xdg_config="$xdg_root/config"
xdg_data="$xdg_root/data"
xdg_state="$xdg_root/state"
xdg_cache="$xdg_root/cache"
artifacts_dir="$tmp_root/artifacts"
old_lockfile="$artifacts_dir/old-lockfile.json"
audit_json="$artifacts_dir/audit.json"
audit_md="$artifacts_dir/audit.md"
summary_txt="$artifacts_dir/summary.txt"
commit_msg="$artifacts_dir/commit-message.txt"

mkdir -p "$xdg_config" "$xdg_data" "$xdg_state" "$xdg_cache" "$artifacts_dir"

printf '%s\n' "creating temp clone in $tmp_root"
git clone --depth=1 "file://$repo_root" "$staging_repo" >/dev/null

cp "$lockfile_path" "$old_lockfile"

ln -s "$staging_repo/core/nvim" "$xdg_config/nvim"

printf '\n%s\n' "staged Neovim instructions:"
printf '%s\n' "1. vim.pack.update() will run automatically"
printf '%s\n' "2. Review the confirmation buffer"
printf '%s\n' "3. Use :write to apply updates or :quit to cancel"
printf '%s\n' "4. Exit Neovim"
printf '\n'

(
  export XDG_CONFIG_HOME="$xdg_config"
  export XDG_DATA_HOME="$xdg_data"
  export XDG_STATE_HOME="$xdg_state"
  export XDG_CACHE_HOME="$xdg_cache"
  cd "$staging_repo"
  nvim "+lua vim.pack.update()" "$staging_repo/core/nvim/nvim-pack-lock.json"
)

staged_lockfile="$staging_repo/$lockfile_rel"

if cmp -s "$old_lockfile" "$staged_lockfile"; then
  printf '%s\n' "no plugin updates applied"
  keep_tmp=0
  exit 0
fi

plugin_root="$xdg_data/nvim/site/pack/core/opt"

printf '%s\n' "running Codex security audit"
cat "$prompt_path" - <<EOF | codex exec \
  --sandbox workspace-write \
  --ephemeral \
  --skip-git-repo-check \
  --output-schema "$schema_path" \
  -o "$audit_json" \
  -C "$tmp_root" \
  -

## Runtime Context

- mode: changed_only
- old_lockfile_path: $old_lockfile
- new_lockfile_path: $staged_lockfile
- plugin_root: $plugin_root
- audit_md_path: $audit_md
EOF

[[ -f "$audit_json" ]] || die "Codex did not produce $audit_json"
[[ -f "$audit_md" ]] || die "Codex did not write $audit_md"

jq -r '
  def plugin_line:
    "- \(.plugin_name): \(.old_rev[0:12]) -> \(.new_rev[0:12]) [\(.verdict)] (+\(.lines_added)/-\(.lines_removed))";
  def finding_line:
    "  * \(.plugin_name): \(.findings[0].severity) - \(.findings[0].title)";

  [
    "Changed plugins: \(.summary.plugins_changed)",
    (.plugins[] | plugin_line),
    "",
    "Top findings:",
    (
      [ .plugins[]
        | select(.findings | length > 0)
        | finding_line
      ] | if length == 0 then "  * none" else .[] end
    ),
    "",
    "Overall verdict: \(.overall_verdict)",
    "Promotion allowed: \(if .overall_verdict == "block" then "no" else "yes" end)",
    "Audit report: '"$audit_md"'"
  ] | .[]
' "$audit_json" | tee "$summary_txt"

if jq -e '.overall_verdict == "block"' "$audit_json" >/dev/null; then
  printf '\n%s\n' "promotion refused: audit verdict is block"
  printf '%s\n' "artifacts kept in $tmp_root"
  exit 2
fi

printf '\n%s' "Promote audited lockfile and commit it? [y/N] "
read -r promote
if [[ ! "$promote" =~ ^[Yy]$ ]]; then
  printf '%s\n' "promotion declined"
  printf '%s\n' "artifacts kept in $tmp_root"
  exit 3
fi

cp "$staged_lockfile" "$lockfile_path"

printf '\n%s\n' "lockfile diff:"
git -C "$repo_root" diff -- "$lockfile_rel" || true

{
  jq -r '.commit.subject' "$audit_json"
  printf '\n'
  jq -r '.commit.body_markdown' "$audit_json"
} >"$commit_msg"

git -C "$repo_root" add -- "$lockfile_rel"
git -C "$repo_root" commit -F "$commit_msg" -- "$lockfile_rel"

printf '\n%s\n' "promoted and committed $lockfile_rel"
keep_tmp=0
