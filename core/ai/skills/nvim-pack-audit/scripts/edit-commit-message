#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
	echo "Usage: core/ai/skills/nvim-pack-audit/scripts/edit-commit-message <state-json> <output-file>" >&2
	exit 1
fi
commit_msg_file=$(jq -r '.commit_msg_file' "$1")
out_file="$2"
if [[ ! -f "$commit_msg_file" ]]; then
	echo "missing commit message: $commit_msg_file" >&2
	exit 1
fi
cp "$commit_msg_file" "$out_file"
echo "wrote commit message template to $out_file"
